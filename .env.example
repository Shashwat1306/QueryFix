# OpenAI API Configuration

# Option 1: Use AIPipe (recommended - no credit card needed)
# Get your token from: https://aipipe.org/login
OPENAI_API_KEY=your-aipipe-token-here
OPENAI_BASE_URL=https://aipipe.org/openai/v1

# Option 2: Use OpenAI directly (requires OpenAI account with credits)
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=  (leave empty or comment out)

# Optional: Change the model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Change the base URL for the SQL debugger server (default: http://localhost:8000)
# BASE_URL=http://localhost:8000
