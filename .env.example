# ============================================================================
# baseline.py Configuration (Optional - only if you want to run baseline.py)
# ============================================================================
# Use AIPipe Token instead of OpenAI key
OPENAI_API_KEY=your-aipipe-token-here
OPENAI_BASE_URL=https://aipipe.org/openai/v1

# Optional: Change model
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# inference.py Configuration (Required for hackathon evaluation)
# ============================================================================
# Your Hugging Face token (MANDATORY - no default)
HF_TOKEN=your-hf-token-here

# Optional: LLM endpoint (default: https://router.huggingface.co/v1)
API_BASE_URL=https://aipipe.org/openai/v1

# Optional: Model identifier (default: Qwen/Qwen2.5-72B-Instruct)
MODEL_NAME=gpt-4o-mini
